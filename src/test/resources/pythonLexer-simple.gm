lexer grammar PythonLexerSimple;

// Keywords
DEF: 'def';
IF: 'if';
ELIF: 'elif';
ELSE: 'else';
WHILE: 'while';
FOR: 'for';
IN: 'in';
RETURN: 'return';
PASS: 'pass';
BREAK: 'break';
CONTINUE: 'continue';
TRUE: 'True';
FALSE: 'False';
NONE: 'None';

// Operators
PLUS: '+';
MINUS: '-';
STAR: '*';
SLASH: '/';
PERCENT: '%';
EQ: '==';
NE: '!=';
LT: '<';
LE: '<=';
GT: '>';
GE: '>=';
ASSIGN: '=';

// Delimiters
LPAREN: '(';
RPAREN: ')';
LBRACK: '[';
RBRACK: ']';
COLON: ':';
COMMA: ',';
DOT: '.';

// Identifiers and literals
NAME: /"[a-zA-Z_][a-zA-Z0-9_]*"/;
NUMBER: /"[0-9]+(\.[0-9]+)?"/;
STRING: /"\"[^\"]*\""|'[^']*'"/;

// Whitespace (including newlines, spaces and tabs)
WS: /"[ \t\r\n]+"/-> skip;

// Comments
COMMENT: /"#[^\n]*"/-> skip;
