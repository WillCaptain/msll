lexer grammar JavaScriptLexerSimple;

// Keywords
LET: 'let';
CONST: 'const';
VAR: 'var';
FUNCTION: 'function';
RETURN: 'return';
IF: 'if';
ELSE: 'else';
WHILE: 'while';
FOR: 'for';

// Operators
PLUS: '+';
MINUS: '-';
STAR: '*';
SLASH: '/';
ASSIGN: '=';
EQ: '==';
NEQ: '!=';
LT: '<';
GT: '>';
LE: '<=';
GE: '>=';

// Delimiters
LPAREN: '(';
RPAREN: ')';
LBRACE: '{';
RBRACE: '}';
SEMI: ';';
COMMA: ',';
DOT: '.';

// Literals
IDENTIFIER: /"[a-zA-Z_][a-zA-Z0-9_]*"/;
NUMBER: /"[0-9]+(\.[0-9]+)?"/;
STRING: /"'([^'\\]|\\.)*'"|"\"([^\"\\]|\\.)*\""/;

// Whitespace
WS: /"[ \t\r\n]+"/-> skip;
