lexer grammar JSONLexer;

// Structural tokens
LBRACE: '{';
RBRACE: '}';
LBRACK: '[';
RBRACK: ']';
COLON: ':';
COMMA: ',';

// Literals
TRUE: 'true';
FALSE: 'false';
NULL: 'null';

// String
STRING: /"\"[^\"]*\""/;

// Number
NUMBER: /"-?[0-9]+(\.[0-9]+)?"/;

// Whitespace
WS: /"[ \t\r\n]+"/-> skip;
